{
  "$schema": "https://opencode.ai/config.json",
  "model": "z8/generic",
  "small_model": "openrouter/openai/gpt-oss-20b:free",
  "provider": {
    "openrouter": {},
    "google-vertex": {},
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.6:latest": {
          "name": "Qwen3.6"
        }
      }
    },
    "z8": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Z8",
      "options": {
        "baseURL": "{env:Z8_API_URL}"
      },
      "models": {
        "generic": {
          "name": "Generic"
        },
        "glm-4.6": {
          "name": "GLM 4.6",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "qwen3-6": {
          "name": "Qwen3.6",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git": "ask",
      "rm": "ask"
    },
    "read": {
      "*": "allow",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": {
      "*": "ask",
      "*.md": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "lsp": {},
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:UPSTASH_CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:TAVILY_API_KEY}"
      },
      "oauth": false,
      "enabled": true
    }
  },
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  }
}
