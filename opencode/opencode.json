{
  "$schema": "https://opencode.ai/config.json",
  "model": "google-vertex-anthropic/claude-opus-4-7@default",
  "provider": {
    "anthropic-vertex": {},
    "google-vertex": {},
    "ollama": {},
    "openrouter": {}
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:UPSTASH_CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true
    },
    "tavily": {
      "type": "remote",
      "url": "https://mcp.tavily.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:TAVILY_API_KEY}"
      },
      "oauth": false,
      "enabled": true
    }
  }
}
