[core]
	editor = code --wait

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[pull]
  rebase = false

[gpg]
  program = /opt/homebrew/bin/gpg

[commit]
	gpgSign = true

[tag]
	gpgSign = true

[user]
	name = tun43p
	email = tun43p@icloud.com

[includeIf "gitdir:~/Library/Mobile Documents/com~apple~CloudDocs/Documents/Code/github.com/tun43p/"]
	path = "~/Library/Mobile Documents/com~apple~CloudDocs/Documents/Code/github.com/tun43p/dotfiles/git/conf.d/github.com/tun43p"

[includeIf "gitdir:~/Library/Mobile Documents/com~apple~CloudDocs/Documents/Code/gitlab.com/"]
	path = "~/Library/Mobile Documents/com~apple~CloudDocs/Documents/Code/github.com/tun43p/dotfiles/git/conf.d/gitlab.com"

[includeIf "gitdir:~/Library/Mobile Documents/com~apple~CloudDocs/Documents/Code/gitlab.innolab.fr/"]
	path = "~/Library/Mobile Documents/com~apple~CloudDocs/Documents/Code/github.com/tun43p/dotfiles/git/conf.d/gitlab.innolab.fr"

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

