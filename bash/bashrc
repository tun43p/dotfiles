#!/usr/bin/env bash

# Enable vi mode
set -o vi

# Vi mode cursor shapes (line for insert, block for normal)
bind 'set show-mode-in-prompt on'
bind 'set vi-ins-mode-string \1\e[6 q\2'
bind 'set vi-cmd-mode-string \1\e[2 q\2'

# Vi mode keybindings
bind -m vi-insert "\C-l":clear-screen
bind -m vi-command "\C-l":clear-screen

# Don't put duplicate lines or lines starting with space in the history
HISTCONTROL=ignoreboth

# Append to the history file, don't overwrite it
shopt -s histappend

# Set history size
HISTSIZE=100000
HISTFILESIZE=200000

# Check the window size after each command
shopt -s checkwinsize

# Enable extended pattern matching
shopt -s extglob

# Enable recursive globbing with **
shopt -s globstar

# Case-insensitive globbing
shopt -s nocaseglob

# Correct minor spelling errors in cd commands
shopt -s cdspell

# Homebrew (macOS)
if [[ -d "/opt/homebrew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Use Starship prompt if available
if command -v starship &> /dev/null; then
    eval "$(starship init bash)"
else
    parse_git_branch() {
        git branch 2> /dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/(\1)/'
    }

    PS1='\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\[\033[01;33m\]$(parse_git_branch)\[\033[00m\]\$ '
fi

# Enable programmable completion features
if ! shopt -oq posix; then
    if [ -f /usr/share/bash-completion/bash_completion ]; then
        . /usr/share/bash-completion/bash_completion
    elif [ -f /etc/bash_completion ]; then
        . /etc/bash_completion
    fi
fi

# macOS bash completion via Homebrew
if [[ -r "/opt/homebrew/etc/profile.d/bash_completion.sh" ]]; then
    . "/opt/homebrew/etc/profile.d/bash_completion.sh"
fi

# ble.sh — Bash Line Editor with autosuggestions (install: brew install blesh)
if [[ -f ~/.local/share/blesh/ble.sh ]]; then
    source ~/.local/share/blesh/ble.sh
fi

# fzf — fuzzy finder with improved keybindings
if [ -f ~/.fzf.bash ]; then
    source ~/.fzf.bash

    # fzf options
    export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border --inline-info"

    # Use fd instead of find if available (faster, respects .gitignore)
    if command -v fd &> /dev/null; then
        export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
        export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    fi

    # Better history search (Ctrl+R)
    export FZF_CTRL_R_OPTS="--preview 'echo {}' --preview-window down:3:hidden:wrap --bind '?:toggle-preview'"
fi

# direnv
if command -v direnv &> /dev/null; then
    eval "$(direnv hook bash)"
fi

# zoxide — smarter cd
if command -v zoxide &> /dev/null; then
    eval "$(zoxide init bash)"
fi

# Source local bashrc if it exists (for machine-specific settings)
if [ -f ~/.bashrc.local ]; then
    source ~/.bashrc.local
fi
