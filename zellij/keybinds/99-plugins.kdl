shared_except "locked" {
    bind "Alt left" {
        MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
            name "move_focus_or_tab"
            payload "left"
            floating false
            move_mod "alt"
            use_arrow_keys true
        }
    }

    bind "Alt down" {
        MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
            name "move_focus"
            payload "down"
            floating false
            move_mod "alt"
            use_arrow_keys true
        }
    }

    bind "Alt up" {
        MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
            name "move_focus"
            payload "up"
            floating false
            move_mod "alt"
            use_arrow_keys true
        }
    }

    bind "Alt right" {
        MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
            name "move_focus_or_tab"
            payload "right"
            floating false
            move_mod "alt"
            use_arrow_keys true
        }
    }

    bind "Alt h" {
        MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
            name "move_focus_or_tab"
            payload "left"
            floating false
            move_mod "alt"
            use_arrow_keys false
        }
    }

    bind "Alt j" {
        MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
            name "move_focus"
            payload "down"
            floating false
            move_mod "alt"
            use_arrow_keys false
        }
    }

    bind "Alt k" {
        MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
            name "move_focus"
            payload "up"
            floating false
            move_mod "alt"
            use_arrow_keys false
        }
    }

    bind "Alt l" {
        MessagePlugin "file:~/.config/zellij/plugins/vim-zellij-navigator.wasm" {
            name "move_focus_or_tab"
            payload "right"
            floating false
            move_mod "alt"
            use_arrow_keys false
        }
    }

    bind "Ctrl y" {
        LaunchOrFocusPlugin "file:~/.config/zellij/plugins/zellij_forgot.wasm" {
            "LOAD_ZELLIJ_BINDINGS" "false"

            // enter/exit modes
            "[mode] Enter locked"            "Ctrl g  (from anywhere)"
            "[mode] Enter pane"              "Ctrl p  (except locked/pane)"
            "[mode] Enter tab"               "Ctrl t  (except locked/tab)"
            "[mode] Enter resize"            "Ctrl n  (except locked/resize)"
            "[mode] Enter move"              "Ctrl h  (except locked/move)"
            "[mode] Enter scroll"            "Ctrl s  (except locked/scroll/search)"
            "[mode] Enter session"           "Ctrl o  (except locked/session)"
            "[mode] Exit → normal"           "Enter or Esc  (most modes)"
            "[mode] Exit scroll/search"      "Ctrl s or Ctrl c  (scroll to bottom)"

            // global (except locked)
            "[global] Quit"                  "Ctrl q"
            "[global] New pane"              "Alt n"
            "[global] Toggle floating panes" "Alt f"
            "[global] Close focused pane"    "Alt x"
            "[global] Resize increase"       "Alt +"
            "[global] Resize decrease"       "Alt -"
            "[global] Move tab left"         "Alt i"
            "[global] Move tab right"        "Alt o"
            "[global] Toggle pane in group"  "Alt p"
            "[global] Toggle group marking"  "Alt Shift p"
            "[global] Previous swap layout"  "Alt ["
            "[global] Next swap layout"      "Alt ]"
            "[global] Navigate panes/tabs"   "Alt h/j/k/l or Alt ←↓↑→"
            "[global] Open zellij-forgot"    "Ctrl y"

            // pane mode (Ctrl p)
            "[pane] Move focus"              "h/j/k/l or ←↓↑→"
            "[pane] Move pane"               "H/J/K/L"
            "[pane] New pane down"           "d"
            "[pane] New pane right"          "r"
            "[pane] New pane stacked"        "s"
            "[pane] Rename pane"             "c"
            "[pane] Embed or float pane"     "e"
            "[pane] Toggle floating panes"   "f"
            "[pane] Toggle fullscreen"       "F"
            "[pane] Toggle pane pinned"      "i"
            "[pane] Toggle pane frames"      "z"
            "[pane] Close pane"             "x"
            "[pane] Switch focus"            "p"

            // tab mode (Ctrl t)
            "[tab] Previous tab"             "h/k or ←/↑"
            "[tab] Next tab"                 "j/l or ↓/→"
            "[tab] Go to tab N"              "1-9"
            "[tab] Move tab left"            "H"
            "[tab] Move tab right"           "L"
            "[tab] Break pane left"          "["
            "[tab] Break pane right"         "]"
            "[tab] Break pane to new tab"    "b"
            "[tab] New tab"                  "n"
            "[tab] Rename tab"               "r"
            "[tab] Toggle sync tab"          "s"
            "[tab] Close tab"                "x"
            "[tab] Toggle last tab"          "Tab"

            // resize mode (Ctrl n)
            "[resize] Increase size"         "h/j/k/l or ←↓↑→"
            "[resize] Decrease size"         "H/J/K/L"
            "[resize] Increase"              "+"
            "[resize] Decrease"              "-"

            // move mode (Ctrl h)
            "[move] Move pane"               "h/j/k/l or ←↓↑→"
            "[move] Move pane forward"       "n or Tab"
            "[move] Move pane backward"      "p"

            // scroll mode (Ctrl s)
            "[scroll] Scroll down"           "j or ↓"
            "[scroll] Scroll up"             "k or ↑"
            "[scroll] Page up"               "h or ← or PageUp or Ctrl b"
            "[scroll] Page down"             "l or → or PageDown or Ctrl f"
            "[scroll] Half page down"        "d"
            "[scroll] Half page up"          "u"
            "[scroll] Enter search"          "s"
            "[scroll] Edit scrollback"       "e"

            // search mode (scroll → s)
            "[search] Next result"           "n"
            "[search] Previous result"       "p"
            "[search] Toggle case sensitive" "c"
            "[search] Toggle whole word"     "o"
            "[search] Toggle wrap"           "w"

            // session mode (Ctrl o)
            "[session] About"                "a"
            "[session] Configuration"        "c"
            "[session] Layout manager"       "l"
            "[session] Plugin manager"       "p"
            "[session] Share session"        "s"
            "[session] Session manager"      "w"

            floating true
        }
    }
}
