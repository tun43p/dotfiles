#!/usr/bin/env zsh

# Homebrew (macOS) — must come before compinit so its completions are found
if [[ -d "/opt/homebrew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
    FPATH="/opt/homebrew/share/zsh/site-functions:$FPATH"
fi

# Enable programmable completion
autoload -Uz compinit
compinit

# History
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=200000
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt APPEND_HISTORY

# Shell options
setopt EXTENDED_GLOB
setopt NO_CASE_GLOB
setopt AUTO_CD
setopt CORRECT

# Prompt with git branch (via vcs_info)
autoload -Uz vcs_info

# Pre-prompt hook to fix current directory name
precmd() {
  vcs_info
  # List parent dir and grep case-insensitively to get the real cased name from filesystem
  local _parent="${PWD:h}" _base="${PWD:t}"
  _PROMPT_DIR=$(ls -1 "$_parent" 2>/dev/null | grep -ix "$_base" | head -1)
  [[ -z "$_PROMPT_DIR" ]] && _PROMPT_DIR="$_base"
  [[ "$PWD" == "$HOME" ]] && _PROMPT_DIR="~"
}

zstyle ':vcs_info:git:*' formats ' (%b)'
setopt PROMPT_SUBST

# Line 1: dirname (bold) + git branch (dim grey)
# Line 2: ❯ cyan on success, red on error
PROMPT='%B%F{white}${_PROMPT_DIR}%f%b%F{242}${vcs_info_msg_0_}%f
%(?.%F{cyan}.%F{red})❯%f '

# zoxide — smarter cd
if command -v zoxide &> /dev/null; then
    eval "$(zoxide init zsh)"
fi

# Navigation aliases
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# ls aliases (color)
alias ls='ls --color=auto'
alias ll='ls -lh'
alias la='ls -lAh'
alias l='ls -CF'

# Safety nets aliases
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# Vim aliases
alias vim='nvim'
alias v='nvim'

# Git aliases
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline --graph --decorate'
alias gd='git diff'

# Terraform aliases
alias tf="terraform"
alias tfi="terraform init"
alias tfp="terraform plan"
alias tfa="terraform apply"

# Claude aliases
alias c="claude"

# Ollama aliases
alias o="ollama"

# Reload zsh alias
alias reload='source ~/.zshrc'

# Claude Code usage aliases
alias ccud="npx ccusage daily --package"
alias ccum="npx ccusage monthly --package"

# macOS specific aliases
if [[ "$OSTYPE" == "darwin"* ]]; then
    alias finder='open -R'
    alias flushdns='sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder'
fi

# Create directory and cd into it
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Extract various archive formats
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1"     ;;
            *.tar.gz)    tar xzf "$1"     ;;
            *.bz2)       bunzip2 "$1"     ;;
            *.rar)       unrar x "$1"     ;;
            *.gz)        gunzip "$1"      ;;
            *.tar)       tar xf "$1"      ;;
            *.tbz2)      tar xjf "$1"     ;;
            *.tgz)       tar xzf "$1"     ;;
            *.zip)       unzip "$1"       ;;
            *.Z)         uncompress "$1"  ;;
            *.7z)        7z x "$1"        ;;
            *)           echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# Find process using a port
port() {
    lsof -i :"$1"
}

# fzf — fuzzy finder keybindings (Ctrl+R: history, Ctrl+T: files, Alt+C: cd)
if [[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]]; then
    source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
fi

# fzf — shell completions (trigger: <cmd> **)
if [[ -f /opt/homebrew/opt/fzf/shell/completion.zsh ]]; then
    source /opt/homebrew/opt/fzf/shell/completion.zsh
fi

# fzf default options
export FZF_DEFAULT_OPTS='--height=40% --layout=reverse --border=rounded --info=inline'

# Use fd if available (respects .gitignore, faster than find)
if command -v fd &>/dev/null; then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
fi

# zsh-autosuggestions (must be sourced before syntax-highlighting)
if [[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
    source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

# zsh-syntax-highlighting (must be sourced last)
if [[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
    source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi
